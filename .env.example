# Database
DB_NAME=loagun
DB_USERNAME=loagun
DB_PASSWORD=your-db-password
DB_ROOT_PASSWORD=your-root-password

# Redis
REDIS_PASSWORD=your-redis-password

# Lostark Open API
LOSTARK_API_KEY=your-lostark-api-key

# Docker Hub
DOCKER_USERNAME=your-dockerhub-username
DOCKER_TOKEN=your-dockerhub-token

# Production Server (for CD)
PROD_HOST=your-server-ip
PROD_USER=ubuntu
# PROD_SSH_KEY: set in GitHub Secrets
